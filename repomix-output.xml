"use client";

import React, { useState, useMemo, useEffect } from "react";
import { Play, Pause, RotateCcw, Download, ShieldAlert, Layers, BarChart3, Info } from "lucide-react";
import { mockCascadeData, infrastructureMetadata, CascadeNode } from "./data/mockCascade";

export default function SocialViralityCascadeExplorer() {
  // Timeline State Control
  const [isPlaying, setIsPlaying] = useState<boolean>(false);
  const [currentTime, setCurrentTime] = useState<number>(0);
  const maxTime = 60; // Minutes matching our mock data timeline
  const [selectedPlatform, setSelectedPlatform] = useState<string>("All");
  const [hoveredNode, setHoveredNode] = useState<CascadeNode | null>(null);

  // Playback loop interval
  useEffect(() => {
    let interval: NodeJS.Timeout;
    if (isPlaying) {
      interval = setInterval(() => {
        setCurrentTime((prev) => {
          if (prev >= maxTime) {
            setIsPlaying(false);
            return maxTime;
          }
          return prev + 1;
        });
      }, 300); // Speed of replay animation
    }
    return () => clearInterval(interval);
  }, [isPlaying]);

  // Filter nodes that have occurred up to the current timeline slider position
  const visibleNodes = useMemo(() => {
    return mockCascadeData.filter((node) => {
      const matchesTime = node.timestamp <= currentTime;
      const matchesPlatform = selectedPlatform === "All" || node.platform === selectedPlatform;
      return matchesTime && matchesPlatform;
    });
  }, [currentTime, selectedPlatform]);

  // Calculate dynamic stats based on current visible timeline window
  const currentMetrics = useMemo(() => {
    const totalVisibleReach = visibleNodes.reduce((acc, curr) => acc + curr.reach, 0);
    return {
      activeNodes: visibleNodes.length,
      accumulatedReach: totalVisibleReach,
      velocity: visibleNodes.length > 1 ? `${Math.round(totalVisibleReach / (currentTime || 1))} views/min` : "0 views/min"
    };
  }, [visibleNodes, currentTime]);

  // Handle data export download
  const downloadSampleData = () => {
    const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(mockCascadeData, null, 2));
    const downloadAnchor = document.createElement("a");
    downloadAnchor.setAttribute("href", dataStr);
    downloadAnchor.setAttribute("download", "social_virality_cascade_sample.json");
    document.body.appendChild(downloadAnchor);
    downloadAnchor.click();
    downloadAnchor.remove();
  };

  return (
    <div className="min-h-screen bg-[#030712] text-slate-100 font-sans selection:bg-cyan-500/30">
      {/* Premium Top Navbar Banner */}
      <header className="border-b border-slate-800/60 bg-[#090d16] px-6 py-4 flex items-center justify-between backdrop-blur-md sticky top-0 z-50">
        <div className="flex items-center space-x-3">
          <div className="h-3 w-3 bg-cyan-500 rounded-full animate-pulse shadow-[0_0_10px_#06b6d4]" />
          <h1 className="text-lg font-semibold tracking-tight text-slate-200">
            Real Rails Intelligence Library <span className="text-slate-500 font-normal">|</span> <span className="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-indigo-400">Social Virality Cascade Explorer</span>
          </h1>
        </div>
        <div className="flex items-center space-x-4">
          <span className="text-xs font-mono uppercase bg-slate-800/60 text-slate-400 border border-slate-700/50 px-2.5 py-1 rounded">
            Rail: Distribution & Demand
          </span>
          <span className="text-xs font-mono uppercase bg-amber-500/10 text-amber-400 border border-amber-500/20 px-2.5 py-1 rounded">
            Synthetic Feed Mode
          </span>
        </div>
      </header>

      {/* Main Container Split: 70% Canvas Main Stage / 30% Narrative Sidebar */}
      <main className="flex flex-col lg:flex-row min-h-[calc(100vh-69px)]">
        
        {/* ========================================================= */}
        {/* LEFT COLUMN: MAIN VISUALIZATION STAGE (70% Area Width)   */}
        {/* ========================================================= */}
        <section className="w-full lg:w-[70%] p-6 flex flex-col border-r border-slate-800/40 space-y-6">
          
          {/* Section Heading & Interactive Filter Strip */}
          <div className="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-slate-800/40 pb-4">
            <div>
              <h2 className="text-md font-medium text-slate-300">Cascade Replay Stage</h2>
              <p className="text-xs text-slate-400 mt-0.5">Watch algorithmic routing vectors propagate audience attention over time grids.</p>
            </div>
            <div className="flex items-center space-x-2">
              <span className="text-xs font-mono text-slate-500 uppercase">Filter Vector:</span>
              <select 
                value={selectedPlatform} 
                onChange={(e) => setSelectedPlatform(e.target.value)}
                className="bg-slate-900 border border-slate-800 text-xs text-slate-300 rounded px-3 py-1.5 focus:outline-none focus:border-cyan-500"
              >
                <option value="All">All Platforms</option>
                <option value="X">X (Twitter)</option>
                <option value="LinkedIn">LinkedIn</option>
                <option value="TikTok">TikTok</option>
                <option value="Reddit">Reddit</option>
              </select>
            </div>
          </div>

          {/* Core Feature: Cascade Graph Simulated Canvas Area */}
          <div className="relative flex-1 min-h-[400px] bg-[#050911] rounded-lg border border-slate-800/80 p-6 overflow-hidden flex flex-col justify-between">
            
            {/* Top Hover Info Box (Rich Tooltip Feature) */}
            <div className="absolute top-4 left-4 z-10 min-w-[240px] max-w-sm bg-[#0a0f1d]/90 backdrop-blur border border-slate-800 rounded p-3 shadow-2xl">
              {hoveredNode ? (
                <div className="space-y-1.5">
                  <div className="flex items-center justify-between">
                    <span className="text-xs font-bold text-cyan-400 font-mono">{hoveredNode.user}</span>
                    <span className="text-[10px] uppercase font-mono px-1.5 py-0.5 rounded bg-slate-800 text-slate-300 border border-slate-700">
                      {hoveredNode.platform}
                    </span>
                  </div>
                  <p className="text-xs text-slate-300 line-clamp-2 italic">"{hoveredNode.content}"</p>
                  <div className="pt-1.5 border-t border-slate-800 flex justify-between text-[10px] font-mono text-slate-400">
                    <span>Reach: <strong className="text-slate-200">{hoveredNode.reach.toLocaleString()}</strong></span>
                    <span>T + {hoveredNode.timestamp}m</span>
                  </div>
                </div>
              ) : (
                <p className="text-xs text-slate-500 flex items-center gap-1.5">
                  <Info size={13} className="text-cyan-500/70" /> Hover over interactive graph nodes to inspect metadata packet trails.
                </p>
              )}
            </div>

            {/* Simulated Node Network Topology Mapping Engine */}
            <div className="w-full h-full flex items-center justify-center relative py-12">
              <svg className="absolute inset-0 w-full h-full pointer-events-none">
                {/* Dynamically draw linking network paths between nodes */}
                {visibleNodes.map((node) => {
                  if (!node.parentId) return null;
                  const parent = mockCascadeData.find(n => n.id === node.parentId);
                  if (!parent) return null;
                  
                  // Simple layout coordinates for demo visualization stability
                  const idx = mockCascadeData.indexOf(node);
                  const pIdx = mockCascadeData.indexOf(parent);
                  const startX = 100 + (pIdx * 60);
                  const startY = 150 + (pIdx % 2 === 0 ? 30 : -30);
                  const endX = 100 + (idx * 60);
                  const endY = 150 + (idx % 2 === 0 ? 30 : -30);

                  return (
                    <line 
                      key={`edge-${node.id}`}
                      x1={startX} y1={startY} x2={endX} y2={endY}
                      className="stroke-slate-800 stroke-2"
                      strokeDasharray="4 4"
                    />
                  );
                })}
              </svg>

              {/* Render Nodes onto structural layouts */}
              <div className="flex flex-wrap justify-center items-center gap-8 max-w-2xl z-10 relative">
                {visibleNodes.map((node) => {
                  const isInfluencer = node.type === "influencer";
                  const isOrigin = node.type === "origin";

                  return (
                    <div
                      key={node.id}
                      onMouseEnter={() => setHoveredNode(node)}
                      onMouseLeave={() => setHoveredNode(null)}
                      className={`relative cursor-crosshair p-3 rounded-md transition-all duration-300 border shadow-2xl flex flex-col items-center justify-center w-24 h-24 text-center
                        ${isOrigin ? "bg-cyan-950/40 border-cyan-500 text-cyan-200 shadow-[0_0_15px_rgba(6,182,212,0.2)]" : ""}
                        ${isInfluencer ? "bg-indigo-950/40 border-indigo-500 text-indigo-200 shadow-[0_0_15px_rgba(99,102,241,0.2)] scale-110" : ""}
                        ${node.type === "organic" ? "bg-slate-900/90 border-slate-700 text-slate-300 hover:border-slate-500" : ""}
                      `}
                    >
                      <span className="text-[10px] font-mono font-bold truncate max-w-full block text-slate-300">
                        {node.user}
                      </span>
                      <span className="text-[9px] text-slate-500 font-mono mt-1 uppercase">
                        {node.platform}
                      </span>
                      <div className="absolute -bottom-1.5 bg-slate-950 px-1.5 py-0.5 rounded border border-slate-800 text-[8px] font-mono text-slate-400">
                        +{node.timestamp}m
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>

            {/* Real-time Dynamic Metrics Strips */}
            <div className="grid grid-cols-3 gap-4 border-t border-slate-900 pt-4 bg-[#070c18] p-3 rounded border border-slate-800/40">
              <div>
                <span className="text-[10px] font-mono text-slate-500 uppercase block">Active Spread Nodes</span>
                <span className="text-md font-mono font-bold text-slate-200">{currentMetrics.activeNodes} / {mockCascadeData.length}</span>
              </div>
              <div>
                <span className="text-[10px] font-mono text-slate-500 uppercase block">Accumulated Reach</span>
                <span className="text-md font-mono font-bold text-cyan-400">{currentMetrics.accumulatedReach.toLocaleString()}</span>
              </div>
              <div>
                <span className="text-[10px] font-mono text-slate-500 uppercase block">Distribution Velocity</span>
                <span className="text-md font-mono font-bold text-indigo-400">{currentMetrics.velocity}</span>
              </div>
            </div>
          </div>

          {/* Core Feature: Replay Mode & Spread Timeline Control Deck */}
          <div className="bg-[#090d16] border border-slate-800/80 rounded-lg p-4 space-y-3">
            <div className="flex items-center justify-between">
              <div className="flex items-center space-x-2">
                <button
                  onClick={() => setIsPlaying(!isPlaying)}
                  className={`p-2 rounded flex items-center justify-center transition-colors ${isPlaying ? "bg-amber-600 hover:bg-amber-700 text-white" : "bg-cyan-600 hover:bg-cyan-700 text-white"}`}
                >
                  {isPlaying ? <Pause size={15} /> : <Play size={15} className="ml-0.5" />}
                </button>
                <button
                  onClick={() => { setIsPlaying(false); setCurrentTime(0); }}
                  className="p-2 bg-slate-800 hover:bg-slate-700 rounded text-slate-300 transition-colors"
                >
                  <RotateCcw size={15} />
                </button>
                <span className="text-xs font-mono text-slate-400 px-2">
                  Timeline Offset: <strong className="text-cyan-400">T + {currentTime} minutes</strong>
                </span>
              </div>
              <span className="text-[11px] font-mono text-slate-500">Temporal Scrubber Engine</span>
            </div>

            {/* The Timeline Slider/Scrubber bar */}
            <input
              type="range"
              min="0"
              max={maxTime}
              value={currentTime}
              onChange={(e) => setCurrentTime(parseInt(e.target.value))}
              className="w-full h-1 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-cyan-500 focus:outline-none"
            />
            <div className="flex justify-between text-[10px] font-mono text-slate-600">
              <span>0m (Origin Event)</span>
              <span>15m</span>
              <span>30m (Peak Impact)</span>
              <span>45m</span>
              <span>60m (Decay Ceiling)</span>
            </div>
          </div>
        </section>

        {/* ========================================================= */}
        {/* RIGHT COLUMN: INTELLIGENCE SIDEBAR PANEL (30% Area Width) */}
        {/* ========================================================= */}
        <section className="w-full lg:w-[30%] bg-[#060a12] p-6 flex flex-col space-y-6">
          
          {/* Section Identification Title */}
          <div>
            <h3 className="text-xs font-mono uppercase tracking-widest text-cyan-500">Intelligence Briefing</h3>
            <h2 className="text-md font-bold text-slate-200 mt-1">Distribution & Demand Mechanics</h2>
          </div>

          <hr className="border-slate-800/60" />

          {/* Required Feature: 'Why This Matters' Panel */}
          <div className="space-y-2">
            <h4 className="text-xs font-semibold text-slate-300 uppercase font-mono flex items-center gap-1.5">
              <BarChart3 size={13} className="text-cyan-400" /> 1. Why This Matters
            </h4>
            <div className="bg-slate-900/60 border border-slate-800/80 rounded p-3.5 text-xs text-slate-400 leading-relaxed space-y-2">
              <p>
                In standard information frameworks, audiences treat news as a purely organic event. This model proves virality behaves under strict, predictable decay half-lives[cite: 1]. 
              </p>
              <p className="text-slate-300 font-medium">
                Distribution concentrates heavily into centralized nodes[cite: 1]. A single influencer node controls more velocity metrics than 90% of structural organic layers combined[cite: 1].
              </p>
            </div>
          </div>

          {/* Required Feature: 'Who Controls the Rail' Panel */}
          <div className="space-y-2">
            <h4 className="text-xs font-semibold text-slate-300 uppercase font-mono flex items-center gap-1.5">
              <ShieldAlert size={13} className="text-indigo-400" /> 2. Who Controls the Rail
            </h4>
            <div className="bg-slate-900/60 border border-slate-800/80 rounded p-3.5 text-xs text-slate-400 leading-relaxed space-y-2">
              <p>
                The underlying attention rail is dictated by centralized sorting filters like Meta, ByteDance, Alphabet, and X Corp[cite: 1]. 
              </p>
              <p className="text-slate-300 font-medium">
                These platforms act as modern routing toll roads, deciding exactly where data packets cascade via programmatic ranking scoring models[cite: 1].
              </p>
            </div>
          </div>

          {/* Required Feature: Decay Curves & Static Insights Metrics Grid */}
          <div className="space-y-2">
            <h4 className="text-xs font-semibold text-slate-300 uppercase font-mono flex items-center gap-1.5">
              <Layers size={13} className="text-amber-400" /> 3. Structural Decay Half-Life
            </h4>
            <div className="bg-slate-900/40 border border-slate-800/60 rounded p-3 text-xs space-y-2.5 font-mono">
              <div className="flex justify-between border-b border-slate-900 pb-1.5">
                <span className="text-slate-500">Global Metric Ceiling:</span>
                <span className="text-slate-300 font-bold">{infrastructureMetadata.totalGlobalReach.toLocaleString()} views</span>
              </div>
              <div className="flex justify-between border-b border-slate-900 pb-1.5">
                <span className="text-slate-500">Velocity Peak Interval:</span>
                <span className="text-slate-300 text-amber-400 font-bold">{infrastructureMetadata.peakVelocity}</span>
              </div>
              <div className="flex justify-between border-b border-slate-900 pb-1.5">
                <span className="text-slate-500">Decay Half-Life Limit:</span>
                <span className="text-slate-300 font-bold">{infrastructureMetadata.decayHalfLife}</span>
              </div>
              <div className="flex justify-between text-[11px]">
                <span className="text-slate-500">Dominant Vector:</span>
                <span className="text-cyan-400 font-bold">{infrastructureMetadata.dominantPlatform}</span>
              </div>
            </div>
          </div>

          <div className="pt-4 mt-auto">
            {/* Required Feature: Downloadable Sample Data Button */}
            <button
              onClick={downloadSampleData}
              className="w-full py-2.5 bg-slate-900 border border-slate-800 hover:border-slate-700 hover:bg-slate-800 rounded text-xs font-mono font-medium text-slate-300 flex items-center justify-center space-x-2 transition-all active:scale-[0.98]"
